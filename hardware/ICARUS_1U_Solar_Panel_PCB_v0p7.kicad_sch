		(text "1S2P baseline (v0.7): SC1_NEG and SC2_NEG -> PANEL_NEG; SC1_POS and SC2_POS -> PANEL_POS. Cells in parallel; eliminates Voc OVP risk. Validate actual cell polarity before assembly." (at 67.31 57.15 0) (effects (font (size 1.27 1.27)) (justify left bottom)) (uuid "d0135269-a5b2-46e3-af33-bd106cd64349"))
